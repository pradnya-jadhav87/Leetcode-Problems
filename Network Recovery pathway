import java.util.*;

class Solution {
    public int minMaxPathScore(int n, int[][] edges, boolean[] online, int k) {
        List<int[]>[] graph = new ArrayList[n];
        for (int i = 0; i < n; i++) {
            graph[i] = new ArrayList<>();
        }
        
        int minWeight = Integer.MAX_VALUE;
        int maxWeight = Integer.MIN_VALUE;

        for (int[] edge : edges) {
            int u = edge[0];
            int v = edge[1];
            int cost = edge[2];
            
            // Exclude edges connected to offline nodes
            if (online[u] && online[v]) {
                graph[u].add(new int[]{v, cost});
                minWeight = Math.min(minWeight, cost);
                maxWeight = Math.max(maxWeight, cost);
            }
        }
        
        if (!online[0] || !online[n - 1]) return -1;

        int left = minWeight;
        int right = maxWeight;
        int ans = -1;

        while (left <= right) {
            int mid = left + (right - left) / 2;
            if (canReach(graph, n, online, k, mid)) {
                ans = mid; // Found a valid path with a bottleneck of at least 'mid'
                left = mid + 1; // Try to find a larger bottleneck
            } else {
                right = mid - 1; // 'mid' bottleneck is too restrictive or unachievable
            }
        }

        return ans;
    }

    private boolean canReach(List<int[]>[] graph, int n, boolean[] online, int k, int threshold) {
        long[] dist = new long[n];
        Arrays.fill(dist, Long.MAX_VALUE);
        dist[0] = 0;

        // Min-heap PriorityQueue for Dijkstra's
        // Stores {current_cost, u}
        PriorityQueue<long[]> pq = new PriorityQueue<>(Comparator.comparingLong(a -> a[0]));
        pq.offer(new long[]{0, 0});

        while (!pq.isEmpty()) {
            long[] curr = pq.poll();
            long currentCost = curr[0];
            int u = (int) curr[1];

            if (u == n - 1) return currentCost <= k;
            if (currentCost > dist[u]) continue;

            for (int[] neighbor : graph[u]) {
                int v = neighbor[0];
                int weight = neighbor[1];

                if (weight >= threshold && online[v]) {
                    if (currentCost + weight < dist[v]) {
                        dist[v] = currentCost + weight;
                        pq.offer(new long[]{dist[v], v});
                    }
                }
            }
        }

        return dist[n - 1] <= k;
    }
}
